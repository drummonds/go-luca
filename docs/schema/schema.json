        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "UUID primary key"
        },
        {
          "name": "knowledge_time",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "When the system learned about this value"
        },
        {
          "name": "param_name",
          "type": "TEXT",
          "nullable": false,
          "comment": "Parameter name (e.g. base-rate)"
