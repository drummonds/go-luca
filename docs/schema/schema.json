    {
      "name": "balances_live",
      "type": "table",
      "comment": "Pre-computed end-of-day balance snapshots. Updated transactionally when movements are recorded via RecordMovementWithProjections. Avoids expensive SUM queries for frequently accessed balances.\n",
      "columns": [
        {
          "name": "account_id",
          "type": "TEXT",
          "nullable": false,
          "comment": "Account this balance belongs to (references accounts.id)"
        },
        {
          "name": "balance",
          "type": "INTEGER",
          "nullable": false,
          "comment": "End-of-day balance in smallest currency unit"
        },
        {
          "name": "balance_date",
          "type": "TEXT",
          "nullable": false,
          "comment": "Date of the balance snapshot (start of day)"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "Auto-incrementing primary key"
        },
        {
          "name": "updated_at",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "When this balance was last recomputed"
        }
      ],
      "indexes": [
        {
          "name": "idx_balances_live_unique",
          "def": "CREATE UNIQUE INDEX idx_balances_live_unique\n    ON balances_live(account_id, balance_date)",
          "table": "balances_live",
          "columns": [
            "account_id",
            "balance_date"
          ]
        },
        {
          "name": "sqlite_autoindex_balances_live_1",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        }
      ],
      "constraints": [
        {
          "name": "id",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_balances_live_1",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        }
      ],
      "def": "CREATE TABLE balances_live (\n    id TEXT PRIMARY KEY,\n    account_id TEXT NOT NULL,\n    balance_date TEXT NOT NULL,\n    balance INTEGER NOT NULL,\n    updated_at TEXT DEFAULT (datetime('now'))\n)"
    },
