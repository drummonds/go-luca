{
  "name": "go-luca",
  "desc": "Movement-based double-entry bookkeeping database schema",
  "tables": [
    {
      "name": "accounts",
      "type": "table",
      "comment": "Chart of accounts. Each account has a hierarchical path (Type:Product:AccountID:Address) and belongs to one of five fundamental types: Asset, Liability, Equity, Income, Expense. An account optionally belongs to a customer (many accounts per customer). Amounts are stored as integers at the precision defined by the commodity's exponent.\n",
      "columns": [
        {
          "name": "account_id",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Specific account identifier within the product"
        },
        {
          "name": "account_type",
          "type": "TEXT",
          "nullable": false,
          "comment": "One of: Asset, Liability, Equity, Income, Expense"
        },
        {
          "name": "address",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Sub-address within the account (e.g. branch). 'Pending' marks pending accounts"
        },
        {
          "name": "commodity",
          "type": "TEXT",
          "nullable": false,
          "default": "'GBP'",
          "comment": "Commodity code (FK to commodities.code)"
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "Timestamp when the account was created"
        },
        {
          "name": "customer_id",
          "type": "TEXT",
          "nullable": true,
          "comment": "Optional owning customer (FK to customers.id). A customer may have many accounts"
        },
        {
          "name": "full_path",
          "type": "TEXT",
          "nullable": false,
          "comment": "Hierarchical account path, e.g. Asset:Bank:Current:Main"
        },
        {
          "name": "gross_interest_rate",
          "type": "TEXT",
          "nullable": false,
          "default": "0",
          "comment": "Gross annual interest rate as a decimal (0.045 = 4.5%)"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "UUID primary key"
        },
        {
          "name": "interest_accumulator",
          "type": "INTEGER",
          "nullable": false,
          "default": "0",
          "comment": "Sub-unit fractions at extended precision (method-dependent)"
        },
        {
          "name": "interest_method",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Interest calculation method (e.g. simple_daily)"
        },
        {
          "name": "is_pending",
          "type": "INTEGER",
          "nullable": true,
          "default": "0",
          "comment": "True if this is a pending/suspense account"
        },
        {
          "name": "opened_at",
          "type": "TEXT",
          "nullable": true,
          "comment": "When the account was opened"
        },
        {
          "name": "product",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Product category within the account type"
        }
      ],
      "indexes": [
        {
          "name": "sqlite_autoindex_accounts_1",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_2",
          "def": "UNIQUE (full_path)",
          "table": "accounts",
          "columns": [
            "full_path"
          ]
        }
      ],
      "constraints": [
        {
          "name": "- (Foreign key ID: 0)",
          "type": "FOREIGN KEY",
          "def": "FOREIGN KEY (customer_id) REFERENCES customers (id) ON UPDATE NO ACTION ON DELETE NO ACTION MATCH NONE",
          "table": "accounts",
          "referenced_table": "customers",
          "columns": [
            "customer_id"
          ],
          "referenced_columns": [
            "id"
          ]
        },
        {
          "name": "- (Foreign key ID: 1)",
          "type": "FOREIGN KEY",
          "def": "FOREIGN KEY (commodity) REFERENCES commodities (code) ON UPDATE NO ACTION ON DELETE NO ACTION MATCH NONE",
          "table": "accounts",
          "referenced_table": "commodities",
          "columns": [
            "commodity"
          ],
          "referenced_columns": [
            "code"
          ]
        },
        {
          "name": "id",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_1",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_2",
          "type": "UNIQUE",
          "def": "UNIQUE (full_path)",
          "table": "accounts",
          "columns": [
            "full_path"
          ]
        }
      ],
      "def": "CREATE TABLE accounts (\n    id TEXT PRIMARY KEY,\n    full_path TEXT NOT NULL UNIQUE,\n    account_type TEXT NOT NULL,\n    product TEXT NOT NULL DEFAULT '',\n    account_id TEXT NOT NULL DEFAULT '',\n    address TEXT NOT NULL DEFAULT '',\n    is_pending INTEGER DEFAULT 0,\n    commodity TEXT NOT NULL DEFAULT 'GBP' REFERENCES commodities(code),\n    customer_id TEXT REFERENCES customers(id),\n    gross_interest_rate TEXT NOT NULL DEFAULT 0,\n    interest_method TEXT NOT NULL DEFAULT '',\n    interest_accumulator INTEGER NOT NULL DEFAULT 0,\n    opened_at TEXT,\n    created_at TEXT DEFAULT (datetime('now'))\n)"
    },
    {
      "name": "aliases",
      "type": "table",
      "comment": "Short name aliases for account paths. Allows .goluca files and users to reference accounts by a short name instead of the full hierarchical path.\n",
      "columns": [
