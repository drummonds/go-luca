{
  "name": "go-luca",
  "desc": "Movement-based double-entry bookkeeping database schema",
  "tables": [
    {
      "name": "accounts",
      "type": "table",
      "comment": "Chart of accounts. Each account has a hierarchical path (Type:Product:AccountID:Address) and belongs to one of five fundamental types: Asset, Liability, Equity, Income, Expense. Amounts are stored as integers at the precision defined by exponent (e.g. -2 for pence).\n",
      "columns": [
        {
          "name": "account_id",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Specific account identifier within the product"
        },
        {
          "name": "account_type",
          "type": "TEXT",
          "nullable": false,
          "comment": "One of: Asset, Liability, Equity, Income, Expense"
        },
        {
          "name": "address",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Sub-address within the account (e.g. branch). 'Pending' marks pending accounts"
        },
        {
          "name": "annual_interest_rate",
          "type": "TEXT",
          "nullable": false,
          "default": "0",
          "comment": "Annual interest rate as a decimal (0.045 = 4.5%)"
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "Timestamp when the account was created"
        },
        {
          "name": "currency",
          "type": "TEXT",
          "nullable": false,
          "default": "'GBP'",
          "comment": "ISO 4217 currency code (e.g. GBP, USD)"
        },
        {
          "name": "exponent",
          "type": "INTEGER",
          "nullable": false,
          "default": "-2",
          "comment": "Decimal exponent for amount precision (-2 = pence, -5 = high precision)"
        },
        {
          "name": "full_path",
          "type": "TEXT",
          "nullable": false,
          "comment": "Hierarchical account path, e.g. Asset:Bank:Current:Main"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "Auto-incrementing primary key"
        },
        {
          "name": "is_pending",
          "type": "INTEGER",
          "nullable": true,
          "default": "0",
          "comment": "True if this is a pending/suspense account"
        },
        {
          "name": "opened_at",
          "type": "TEXT",
          "nullable": true
        },
        {
          "name": "product",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Product category within the account type"
        }
      ],
      "indexes": [
        {
          "name": "sqlite_autoindex_accounts_1",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_2",
          "def": "UNIQUE (full_path)",
          "table": "accounts",
          "columns": [
            "full_path"
          ]
        }
      ],
      "constraints": [
        {
          "name": "id",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_1",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "accounts",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_accounts_2",
          "type": "UNIQUE",
          "def": "UNIQUE (full_path)",
          "table": "accounts",
          "columns": [
            "full_path"
          ]
        }
      ],
      "def": "CREATE TABLE accounts (\n    id TEXT PRIMARY KEY,\n    full_path TEXT NOT NULL UNIQUE,\n    account_type TEXT NOT NULL,\n    product TEXT NOT NULL DEFAULT '',\n    account_id TEXT NOT NULL DEFAULT '',\n    address TEXT NOT NULL DEFAULT '',\n    is_pending INTEGER DEFAULT 0,\n    currency TEXT NOT NULL DEFAULT 'GBP',\n    exponent INTEGER NOT NULL DEFAULT -2,\n    annual_interest_rate TEXT NOT NULL DEFAULT 0,\n    opened_at TEXT,\n    created_at TEXT DEFAULT (datetime('now'))\n)"
    },
