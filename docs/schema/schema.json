      "def": "CREATE TABLE commodities (\n    id TEXT PRIMARY KEY,\n    code TEXT NOT NULL UNIQUE,\n    exponent INTEGER NOT NULL DEFAULT -2,\n    datetime TEXT,\n    created_at TEXT DEFAULT (datetime('now'))\n)"
