    {
      "name": "movements",
      "type": "table",
      "comment": "Core transaction records. Each movement transfers an integer amount from one account to another. Movements with the same batch_id form a linked transaction (compound entry). Inspired by TigerBeetle's transfer model with code, ledger, and pending_id fields.\n",
      "columns": [
        {
          "name": "amount",
          "type": "INTEGER",
          "nullable": false,
          "comment": "Transfer amount in smallest currency unit (integer at account exponent)"
        },
        {
          "name": "batch_id",
          "type": "TEXT",
          "nullable": false,
          "comment": "Groups related movements into a single atomic transaction"
        },
        {
          "name": "code",
          "type": "INTEGER",
          "nullable": false,
          "default": "0",
          "comment": "Movement category: 0=normal, 1=interest accrual (TigerBeetle-inspired)"
        },
        {
          "name": "description",
          "type": "TEXT",
          "nullable": false,
          "default": "''",
          "comment": "Human-readable description of the movement"
        },
        {
          "name": "from_account_id",
          "type": "TEXT",
          "nullable": false,
          "comment": "Source account (references accounts.id)"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "Auto-incrementing primary key"
        },
        {
          "name": "knowledge_time",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "When the system recorded this movement (knowledge date)"
        },
        {
          "name": "ledger",
          "type": "INTEGER",
          "nullable": false,
          "default": "0",
          "comment": "Partition identifier for multi-ledger setups (TigerBeetle-inspired)"
        },
        {
          "name": "pending_id",
          "type": "INTEGER",
          "nullable": false,
          "default": "0",
          "comment": "Two-phase commit: references pending movement to post/void (0=N/A)"
        },
        {
          "name": "period_anchor",
          "type": "TEXT",
          "nullable": false,
          "default": "''"
        },
        {
          "name": "to_account_id",
          "type": "TEXT",
          "nullable": false,
          "comment": "Destination account (references accounts.id)"
        },
        {
          "name": "user_data_64",
          "type": "INTEGER",
          "nullable": false,
          "default": "0",
          "comment": "Arbitrary external reference for application use"
        },
        {
          "name": "value_time",
          "type": "TEXT",
          "nullable": false,
          "comment": "When the movement economically occurred (value date)"
        }
      ],
      "indexes": [
        {
          "name": "idx_movements_batch",
          "def": "CREATE INDEX idx_movements_batch ON movements(batch_id)",
          "table": "movements",
          "columns": [
            "batch_id"
          ]
        },
        {
