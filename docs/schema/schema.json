          "table": "aliases",
          "columns": [
            "name"
          ]
        }
      ],
      "constraints": [
        {
          "name": "- (Foreign key ID: 0)",
          "type": "FOREIGN KEY",
          "def": "FOREIGN KEY (account_path) REFERENCES accounts (full_path) ON UPDATE NO ACTION ON DELETE NO ACTION MATCH NONE",
          "table": "aliases",
          "referenced_table": "accounts",
          "columns": [
            "account_path"
          ],
          "referenced_columns": [
            "full_path"
          ]
        },
        {
          "name": "id",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "aliases",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_aliases_1",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "aliases",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_aliases_2",
          "type": "UNIQUE",
          "def": "UNIQUE (name)",
          "table": "aliases",
          "columns": [
            "name"
          ]
        }
      ],
      "def": "CREATE TABLE aliases (\n    id TEXT PRIMARY KEY,\n    name TEXT NOT NULL UNIQUE,\n    account_path TEXT NOT NULL REFERENCES accounts(full_path),\n    created_at TEXT DEFAULT (datetime('now'))\n)"
    },
    {
      "name": "balances_live",
      "type": "table",
      "comment": "Pre-computed end-of-day balance snapshots for today and tomorrow only. Holds at most two days of balances per account — older entries are pruned. Updated transactionally when movements are recorded via RecordMovementWithProjections. Avoids expensive SUM queries for frequently accessed current and projected balances.\n",
      "columns": [
        {
          "name": "account_id",
          "type": "TEXT",
          "nullable": false,
          "comment": "Account this balance belongs to (FK to accounts.id)"
        },
        {
          "name": "balance",
          "type": "INTEGER",
          "nullable": false,
          "comment": "End-of-day balance in smallest currency unit"
        },
        {
          "name": "balance_date",
          "type": "TEXT",
          "nullable": false,
          "comment": "Date of the balance snapshot (start of day)"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "UUID primary key"
        },
        {
          "name": "updated_at",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "When this balance was last recomputed"
        }
      ],
      "indexes": [
        {
          "name": "idx_balances_live_unique",
          "def": "CREATE UNIQUE INDEX idx_balances_live_unique\n    ON balances_live(account_id, balance_date)",
          "table": "balances_live",
          "columns": [
            "account_id",
            "balance_date"
          ]
        },
        {
          "name": "sqlite_autoindex_balances_live_1",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        }
      ],
      "constraints": [
        {
          "name": "- (Foreign key ID: 0)",
          "type": "FOREIGN KEY",
          "def": "FOREIGN KEY (account_id) REFERENCES accounts (id) ON UPDATE NO ACTION ON DELETE NO ACTION MATCH NONE",
          "table": "balances_live",
          "referenced_table": "accounts",
          "columns": [
            "account_id"
          ],
          "referenced_columns": [
            "id"
          ]
        },
        {
          "name": "id",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        },
        {
          "name": "sqlite_autoindex_balances_live_1",
          "type": "PRIMARY KEY",
          "def": "PRIMARY KEY (id)",
          "table": "balances_live",
          "columns": [
            "id"
          ]
        }
      ],
      "def": "CREATE TABLE balances_live (\n    id TEXT PRIMARY KEY,\n    account_id TEXT NOT NULL REFERENCES accounts(id),\n    balance_date TEXT NOT NULL,\n    balance INTEGER NOT NULL,\n    updated_at TEXT DEFAULT (datetime('now'))\n)"
    },
    {
      "name": "commodities",
      "type": "table",
      "comment": "Currency/commodity definitions. Each commodity has a unique code and an exponent that defines the precision of amounts (e.g. -2 for pence). Accounts reference commodities via foreign key.\n",
      "columns": [
        {
          "name": "code",
          "type": "TEXT",
          "nullable": false,
          "comment": "Unique commodity code (e.g. GBP, USD, BTC)"
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "nullable": true,
          "default": "datetime('now')",
          "comment": "Timestamp when the commodity was created"
        },
        {
          "name": "datetime",
          "type": "TEXT",
          "nullable": true,
          "comment": "Optional date associated with the commodity definition"
        },
        {
          "name": "exponent",
          "type": "INTEGER",
          "nullable": false,
          "default": "-2",
          "comment": "Decimal exponent for amount precision (-2 = pence, -8 = satoshi)"
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": true,
          "comment": "UUID primary key"
        }
      ],
      "indexes": [
